# Copy to .env (in this docker/ directory) before running docker compose.

# --- Google OAuth for the /admin/chatbot console (required) ---------------
# Setup: https://console.cloud.google.com/apis/credentials
# Create an OAuth client ID (Web application) and add this redirect URI:
#   https://YOUR_DOMAIN/admin/chatbot/api/auth/callback
# (for a local test: http://localhost:3000/admin/chatbot/api/auth/callback)
CHATBOT_GOOGLE_CLIENT_ID=
CHATBOT_GOOGLE_CLIENT_SECRET=

# Comma-separated Google account emails allowed to sign in. Case-insensitive.
CHATBOT_ALLOWED_EMAILS=you@example.com

# Public origin where this container is reachable. Required behind a reverse
# proxy / domain so OAuth redirects and the embed snippet use the right URL.
# For a local test on the default port, use http://localhost:3000
CHATBOT_BASE_URL=https://chat.example.com

# Comma-separated origins allowed to embed the widget on another site
# (e.g. https://yourportfolio.com). Use * to allow any origin. Optional.
CHATBOT_ALLOWED_ORIGINS=

# LLM API keys are normally pasted in the admin "Connections" tab. You can
# also set a fallback key here (the UI value wins). Optional.
# GEMINI_API_KEY=
