# Copy to .env.local and fill in your own values.

# Google OAuth for the /admin/chatbot route (required).
# Setup: https://console.cloud.google.com/apis/credentials
# 1) Create credentials → OAuth client ID → Web application.
# 2) Under "Authorized redirect URIs", add:
#       http://localhost:3000/admin/chatbot/api/auth/callback         (for local dev)
#       https://YOUR_DOMAIN/admin/chatbot/api/auth/callback           (for production — add separately)
# 3) Copy the client ID + secret here:
CHATBOT_GOOGLE_CLIENT_ID=
CHATBOT_GOOGLE_CLIENT_SECRET=

# Comma-separated list of Google account emails allowed to sign in. Case-insensitive.
CHATBOT_ALLOWED_EMAILS=

# Public origin of this deployment, e.g. https://chat.example.com
# Required when running behind a reverse proxy (Docker, a CDN) so the OAuth
# redirect and the embed snippet use the right URL. Leave blank for local dev.
CHATBOT_BASE_URL=

# Comma-separated list of origins allowed to embed the chat widget on another
# site (e.g. https://yourportfolio.com). Leave blank to disable cross-origin
# embedding. Use * to allow any origin.
CHATBOT_ALLOWED_ORIGINS=

# Directory where profile.json and secrets.json are stored. Defaults to the
# project root. In Docker this is set to /data (a persisted volume).
# CHATBOT_DATA_DIR=

# LLM API keys are managed inside the admin "Connections" tab (stored in secrets.json).
# You can ALSO set them here as a fallback; values set in the UI override these.
# Free Gemini key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# Email notifications (configured inside admin "Notifications" tab, stored in secrets.json).
# - Gmail: reuses the CHATBOT_GOOGLE_CLIENT_ID / _SECRET above. You need to enable the Gmail API in
#   your GCP project (https://console.cloud.google.com/apis/library/gmail.googleapis.com) and grant
#   the gmail.send scope when you click "Connect Gmail" in the admin UI.
# - SMTP: paste host/port/user/pass in the admin UI; nothing to set here.
